%% Compatibility shim for the package rename
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{myanmar}[2026/05/29 v1.0 Compatibility shim — load myanmar-script]

% Inform the user that the package id has been renamed to avoid a confusing
% authoritative package id on CTAN. This shim loads the real implementation
% from `myanmar-script.sty` if available.
\PackageWarning{myanmar}{The package `myanmar' has been renamed to `myanmar-script'.\MessageBreak Please use `myanmar-script' when possible; this shim will load the real package if found.}

\IfFileExists{myanmar-script.sty}{
  \RequirePackage{myanmar-script}
}{
  \PackageWarning{myanmar}{Could not find `myanmar-script.sty'.\MessageBreak Falling back to built-in (minimal) definitions.}
  % Minimal fallback so documents don't completely fail; keep behaviour small
  \RequirePackage{fontspec}
  \newcommand{\textmyanmar}[1]{{#1}}
  \newenvironment{myanmar}{}{}
  \newcommand{\myanmarnumber}[1]{#1}
}

\endinput
